breadcrumbs class_name: "mb-5" do |trail|
  page_context.breadcrumbs.each do |entry|
    trail.crumb entry.fetch(:label), entry[:href], current: entry[:current]
  end
end

page_header title: page_context.title,
            eyebrow: "Assistant Surface",
            description: page_context.description,
            class_name: "relative overflow-hidden rounded-[34px] border border-orange-200/15 bg-[radial-gradient(circle_at_top_left,_rgba(194,107,61,0.24),_transparent_18rem),linear-gradient(145deg,rgba(60,33,21,0.96),rgba(22,15,13,0.98))] px-6 py-8 shadow-2xl shadow-black/25 sm:px-8 lg:px-10" do
  meta do
    text_node "generated=#{page_context.generated_at} · "
    text_node "requests=#{page_context.assistant_summary.fetch(:total_requests, 0)} · "
    text_node "followups=#{page_context.assistant_summary.fetch(:actionable_followups, 0)}"
  end

  actions do
    action_group class_name: "mt-4 flex flex-wrap gap-3" do |actions|
      page_context.operator_links.each do |entry|
        actions.link entry.fetch(:label),
                     href: entry.fetch(:href),
                     class_name: "rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-stone-100 transition hover:border-orange-300/50 hover:text-orange-200"
      end
    end
  end
end

metric_grid class_name: "grid gap-4 md:grid-cols-3" do
  page_context.summary_metrics.each do |metric|
    metric metric.fetch(:label), metric.fetch(:value), hint: metric.fetch(:hint)
  end
end

shell_columns do |columns|
  columns.main do
    panel title: "Assistant Intake",
          subtitle: "Open a real assistant workflow and send the next step into the operator loop.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      if page_context.assistant_notice
        p page_context.assistant_notice,
          class: "mb-4 rounded-2xl border border-emerald-300/20 bg-emerald-300/10 px-4 py-3 text-sm text-emerald-100"
      end

      if page_context.error_message
        p page_context.error_message,
          class: "mb-4 rounded-2xl border border-rose-300/20 bg-rose-300/10 px-4 py-3 text-sm text-rose-100"
      end

      form action: page_context.route("/assistant/requests"), method: "post", class: "grid gap-3" do
        label "Requester",
              for: "assistant-requester",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-requester",
              name: "requester",
              value: page_context.assistant_form_defaults.fetch("requester"),
              placeholder: "Alex",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        label "Scenario",
              for: "assistant-request-scenario",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        select id: "assistant-request-scenario",
               name: "scenario",
               class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white focus:border-orange-300/50 focus:outline-none" do
          page_context.assistant_scenario_cards.each do |scenario|
            option scenario.fetch(:label),
                   value: scenario.fetch(:key),
                   selected: page_context.assistant_form_defaults.fetch("scenario") == scenario.fetch(:key).to_s
          end
        end
        card title: "Incident Triage Details",
             subtitle: "These fields are especially useful when the scenario is Incident Triage." do
          label "Affected System",
                for: "assistant-affected-system",
                class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          input type: "text",
                id: "assistant-affected-system",
                name: "affected_system",
                value: page_context.assistant_form_defaults.fetch("affected_system"),
                placeholder: "dashboard-api, cluster mesh, auth webhook",
                class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Urgency",
                for: "assistant-urgency",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          select id: "assistant-urgency",
                 name: "urgency",
                 class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white focus:border-orange-300/50 focus:outline-none" do
            %w[critical high medium low].each do |value|
              option value.capitalize, value: value, selected: page_context.assistant_form_defaults.fetch("urgency") == value
            end
          end
          label "Symptoms",
                for: "assistant-symptoms",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.assistant_form_defaults.fetch("symptoms", ""),
                   id: "assistant-symptoms",
                   name: "symptoms",
                   rows: 3,
                   placeholder: "timeouts, 5xx spikes, missing events, delayed replies",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end
        card title: "Technical Rollout Details",
             subtitle: "Use these when the scenario is Technical Rollout or when a change needs clear rollout gates." do
          label "Target Environment",
                for: "assistant-target-environment",
                class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          input type: "text",
                id: "assistant-target-environment",
                name: "target_environment",
                value: page_context.assistant_form_defaults.fetch("target_environment"),
                placeholder: "staging, production-eu, cluster-seed-a",
                class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Change Scope",
                for: "assistant-change-scope",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.assistant_form_defaults.fetch("change_scope", ""),
                   id: "assistant-change-scope",
                   name: "change_scope",
                   rows: 3,
                   placeholder: "what is being rolled out, migrated, or changed",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Verification Plan",
                for: "assistant-verification-plan",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.assistant_form_defaults.fetch("verification_plan", ""),
                   id: "assistant-verification-plan",
                   name: "verification_plan",
                   rows: 3,
                   placeholder: "health checks, smoke tests, success signals",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Rollback Plan",
                for: "assistant-rollback-plan",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.assistant_form_defaults.fetch("rollback_plan", ""),
                   id: "assistant-rollback-plan",
                   name: "rollback_plan",
                   rows: 3,
                   placeholder: "rollback trigger, fallback path, blast-radius limit",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end
        card title: "Research Synthesis Details",
             subtitle: "Use these when the scenario is Research Synthesis or when a brief should be evidence-driven." do
          label "Sources",
                for: "assistant-sources",
                class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.assistant_form_defaults.fetch("sources", ""),
                   id: "assistant-sources",
                   name: "sources",
                   rows: 3,
                   placeholder: "links, notes, docs, datasets, interviews",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Decision Focus",
                for: "assistant-decision-focus",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          input type: "text",
                id: "assistant-decision-focus",
                name: "decision_focus",
                value: page_context.assistant_form_defaults.fetch("decision_focus"),
                placeholder: "Which option should we choose next?",
                class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Constraints",
                for: "assistant-constraints",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.assistant_form_defaults.fetch("constraints", ""),
                   id: "assistant-constraints",
                   name: "constraints",
                   rows: 3,
                   placeholder: "budget, time, compliance, platform limits",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end
        card title: "Artifacts",
             subtitle: "Attach evidence as one item per line. Prefix with `url:`, `file:`, `log:`, or leave plain text for notes." do
          textarea page_context.assistant_form_defaults.fetch("artifacts", ""),
                   id: "assistant-artifacts",
                   name: "artifacts",
                   rows: 4,
                   placeholder: "url: https://example.com/report\nfile: logs/deploy.log\nnote: operator note",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end
        label "Request",
              for: "assistant-request",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        textarea page_context.assistant_form_defaults.fetch("request", ""),
                 id: "assistant-request",
                 name: "request",
                 rows: 4,
                 placeholder: "Prepare a concise assistant brief with the next best operator follow-up.",
                 class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        button "Open Assistant Request",
               type: "submit",
               class: "inline-flex w-fit items-center rounded-full bg-orange-400 px-5 py-2 text-sm font-semibold text-stone-950 transition hover:bg-orange-300"
      end

      card title: "Scenario Presets", subtitle: "Companion should shape the brief around a real working lane, not just generic text." do
        resource_list class_name: "space-y-3" do
          page_context.assistant_scenario_cards.each do |scenario|
            li class: "rounded-2xl border border-white/10 bg-white/5 p-4" do
              div class: "flex flex-wrap items-center gap-3" do
                strong scenario.fetch(:label), class: "font-semibold text-white"
                badge scenario.fetch(:key), size: :sm
              end
              div class: "mt-2 text-sm leading-6 text-stone-300" do
                text_node scenario.fetch(:summary)
              end
              card title: "Expected Shape", subtitle: scenario.fetch(:prompt_hint) do
                line :sections, scenario.fetch(:output_sections), as: :badge
                line :handoff, scenario.fetch(:operator_handoff), as: :code
              end
            end
          end
        end
      end
    end

    panel title: "Assistant Requests",
          subtitle: "Durable request records and their current workflow state.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
        table_with page_context.assistant_request_rows, compact: true, empty_message: "No assistant requests opened yet." do |table|
          table.column :requester
          table.column :scenario, as: :badge, badge: { size: :sm }, placeholder: "--"
          table.column :scenario_summary, as: :code, placeholder: "--"
          table.column :artifacts, as: :number, placeholder: "--"
          table.column :status, as: :badge, badge: { size: :sm }
          table.column :runtime_mode, as: :badge, badge: { size: :sm }
          table.column :runtime_model, as: :code
        table.column :submitted_at, as: :datetime
        table.column :request, placeholder: "--"
      end
    end

    panel title: "Completed Briefings",
          subtitle: "Recent assistant outputs with the runtime profile and external API handoff package.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      if page_context.completed_assistant_requests.empty?
        empty_state "No completed briefings yet",
                    message: "Complete a manual follow-up or let a ready local model auto-draft the first briefing.",
                    class_name: "mt-1"
      else
        resource_list class_name: "space-y-4" do
          page_context.completed_assistant_requests.each do |record|
            li class: "rounded-3xl border border-white/10 bg-white/5 p-4" do
              div class: "flex flex-wrap items-center gap-3" do
                strong record.fetch(:requester), class: "font-semibold text-white"
                badge record.fetch(:status), size: :sm
                badge(record.dig(:scenario, :label) || record.fetch(:scenario_label, "General Brief"), size: :sm)
                badge(record.fetch(:runtime_profile_label, "Operator Brief"), size: :sm)
                code record.fetch(:runtime_model, "--"), class: "rounded-xl bg-black/25 px-2 py-1 text-xs text-stone-300"
              end
              p record.fetch(:request), class: "mt-3 text-sm leading-6 text-stone-300"
              if record[:scenario].is_a?(Hash)
                card title: "Scenario", subtitle: "What kind of assistant outcome this request is aiming for" do
                  line :summary, record.dig(:scenario, :summary), as: :code
                  line :sections, record.dig(:scenario, :output_sections), as: :badge
                  line :handoff, record.dig(:scenario, :operator_handoff), as: :code
                end
              end
              unless page_context.scenario_context_rows(record).empty?
                card title: "Scenario Context", subtitle: "Structured context captured with the request" do
                  page_context.scenario_context_rows(record).each do |row|
                    line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                  end
                end
              end
              unless page_context.artifact_rows(record).empty?
                card title: "Artifacts", subtitle: "Evidence carried with the request" do
                  table_with page_context.artifact_rows(record), compact: true do |table|
                    table.column :kind, as: :badge, badge: { size: :sm }
                    table.column :label, as: :badge, badge: { size: :sm }
                    table.column :value, as: :code
                  end
                end
              end
              unless page_context.operator_checklist_rows(record).empty?
                card title: "Operator Checklist", subtitle: "Practical next checks for this lane" do
                  page_context.operator_checklist_rows(record).each do |row|
                    line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                  end
                end
              end
              card title: "Briefing Preview", subtitle: "Stored result" do
                line :briefing, record.fetch(:briefing, "--"), placeholder: "--"
                line :completed_at, record.fetch(:completed_at, nil), as: :datetime, placeholder: "--"
              end

              card title: "Prompt Package", subtitle: "Prepared for the external ChatGPT API lane" do
                page_context.prompt_package_rows(record).each do |row|
                  line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                end
                viz page_context.prompt_package_preview(record), compact: true
              end

              unless page_context.delivery_rows(record).empty?
                card title: "Delivery Outcome", subtitle: "What happened on the selected external channel" do
                  page_context.delivery_rows(record).each do |row|
                    line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                  end
                  unless page_context.delivery_preview(record).empty?
                    viz page_context.delivery_preview(record), compact: true
                  end
                end
              end

              action_group class_name: "mt-4 flex flex-wrap gap-3" do |actions|
                actions.link "Promote to Rollout",
                             href: page_context.completed_briefing_rollout_href(record),
                             class_name: "rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-stone-100 transition hover:border-orange-300/50 hover:text-orange-200"
              end

              form action: page_context.route("/assistant/requests/reopen"), method: "post", class: "mt-3" do
                input type: "hidden", name: "request_id", value: record.fetch(:id)
                button "Re-open as Manual Action",
                       type: "submit",
                       class: "inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-stone-100 transition hover:border-orange-300/50 hover:text-orange-200"
              end

              form action: page_context.route("/assistant/requests/note"), method: "post", class: "mt-3" do
                input type: "hidden", name: "request_id", value: record.fetch(:id)
                button "Save as Note",
                       type: "submit",
                       class: "inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-stone-100 transition hover:border-orange-300/50 hover:text-orange-200"
              end

              form action: page_context.route("/assistant/requests/feedback"), method: "post", class: "mt-3 grid gap-3" do
                input type: "hidden", name: "request_id", value: record.fetch(:id)
                div class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300" do
                  text_node "Quick Feedback"
                end
                div class: "flex flex-wrap gap-3" do
                  page_context.feedback_options.each do |option|
                    button option.fetch(:label),
                           type: "submit",
                           name: "feedback",
                           value: option.fetch(:value),
                           class: "rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-stone-100 transition hover:border-orange-300/50 hover:text-orange-200"
                  end
                end
              end

              form action: page_context.route("/assistant/requests/redeliver"), method: "post", class: "mt-3" do
                input type: "hidden", name: "request_id", value: record.fetch(:id)
                button "Re-deliver",
                       type: "submit",
                       class: "inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-stone-100 transition hover:border-orange-300/50 hover:text-orange-200"
              end
            end
          end
        end
      end
    end

    panel title: "Workflow Feed",
          subtitle: "Recent orchestration records projected from assistant requests.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      table_with page_context.assistant_followups, compact: true, empty_message: "No orchestration activity yet." do |table|
        table.column :node
        table.column :action, as: :badge, badge: { size: :sm }
        table.column :status, as: :badge, badge: { size: :sm }
        table.column :queue, placeholder: "--"
      end
    end

    panel title: "Model Lab",
          subtitle: "Run the same request against several local models and compare how they draft the briefing.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      form action: page_context.route("/assistant/compare"), method: "post", class: "grid gap-3" do
        label "Requester",
              for: "assistant-compare-requester",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-compare-requester",
              name: "requester",
              value: page_context.compare_form_defaults.fetch("requester"),
              placeholder: "Alex",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        label "Scenario",
              for: "assistant-compare-scenario",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        select id: "assistant-compare-scenario",
               name: "scenario",
               class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white focus:border-orange-300/50 focus:outline-none" do
          page_context.assistant_scenario_cards.each do |scenario|
            option scenario.fetch(:label),
                   value: scenario.fetch(:key),
                   selected: page_context.compare_form_defaults.fetch("scenario") == scenario.fetch(:key).to_s
          end
        end
        card title: "Research Inputs",
             subtitle: "Optional research context for comparing model output quality on the same evidence set." do
          label "Sources",
                for: "assistant-compare-sources",
                class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.compare_form_defaults.fetch("sources", ""),
                   id: "assistant-compare-sources",
                   name: "sources",
                   rows: 3,
                   placeholder: "links, notes, docs, datasets, interviews",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Decision Focus",
                for: "assistant-compare-decision-focus",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          input type: "text",
                id: "assistant-compare-decision-focus",
                name: "decision_focus",
                value: page_context.compare_form_defaults.fetch("decision_focus"),
                placeholder: "Which option should we choose next?",
                class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Constraints",
                for: "assistant-compare-constraints",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.compare_form_defaults.fetch("constraints", ""),
                   id: "assistant-compare-constraints",
                   name: "constraints",
                   rows: 3,
                   placeholder: "budget, time, compliance, platform limits",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end
        card title: "Rollout Inputs",
             subtitle: "Optional rollout context for comparing how models sequence and de-risk the same change." do
          label "Target Environment",
                for: "assistant-compare-target-environment",
                class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          input type: "text",
                id: "assistant-compare-target-environment",
                name: "target_environment",
                value: page_context.compare_form_defaults.fetch("target_environment"),
                placeholder: "staging, production-eu, cluster-seed-a",
                class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Change Scope",
                for: "assistant-compare-change-scope",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.compare_form_defaults.fetch("change_scope", ""),
                   id: "assistant-compare-change-scope",
                   name: "change_scope",
                   rows: 3,
                   placeholder: "what is being rolled out, migrated, or changed",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Verification Plan",
                for: "assistant-compare-verification-plan",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.compare_form_defaults.fetch("verification_plan", ""),
                   id: "assistant-compare-verification-plan",
                   name: "verification_plan",
                   rows: 3,
                   placeholder: "health checks, smoke tests, success signals",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
          label "Rollback Plan",
                for: "assistant-compare-rollback-plan",
                class: "mt-3 text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
          textarea page_context.compare_form_defaults.fetch("rollback_plan", ""),
                   id: "assistant-compare-rollback-plan",
                   name: "rollback_plan",
                   rows: 3,
                   placeholder: "rollback trigger, fallback path, blast-radius limit",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end
        card title: "Artifacts",
             subtitle: "Use the same artifacts across several local models for a fair comparison." do
          textarea page_context.compare_form_defaults.fetch("artifacts", ""),
                   id: "assistant-compare-artifacts",
                   name: "artifacts",
                   rows: 4,
                   placeholder: "url: https://example.com/report\nfile: logs/deploy.log\nnote: operator note",
                   class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
        end

        label "Request",
              for: "assistant-compare-request",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        textarea page_context.compare_form_defaults.fetch("request", ""),
                 id: "assistant-compare-request",
                 name: "request",
                 rows: 4,
                 placeholder: "Compare how local models brief the same task.",
                 class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        label "Models (comma separated)",
              for: "assistant-compare-models",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-compare-models",
              name: "models_csv",
              value: page_context.compare_form_defaults.fetch("models_csv"),
              placeholder: "qwen3:latest, qwen2.5-coder:latest, gpt-oss:latest",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        button "Compare Models",
               type: "submit",
               class: "inline-flex w-fit items-center rounded-full bg-orange-400 px-5 py-2 text-sm font-semibold text-stone-950 transition hover:bg-orange-300"
      end

      if page_context.compare_results_present?
        card title: "Comparison Summary", subtitle: "Availability and completion across selected models" do
          page_context.compare_summary_rows.each do |row|
            line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
          end
        end

        table_with page_context.compare_result_rows, compact: true do |table|
          table.column :model, as: :code
          table.column :profile, as: :badge, badge: { size: :sm }
          table.column :status, as: :badge, badge: { size: :sm }
          table.column :reason, as: :badge, badge: { size: :sm }
          table.column :ready, as: :boolean
        end

        resource_list class_name: "space-y-4" do
          page_context.compare_result_cards.each do |entry|
            li class: "rounded-3xl border border-white/10 bg-white/5 p-4" do
              div class: "flex flex-wrap items-center gap-3" do
                strong entry.fetch(:model), class: "font-semibold text-white"
                badge entry.fetch(:profile_label), size: :sm
                badge entry.fetch(:status), size: :sm
                badge entry.fetch(:reason), size: :sm
              end

              card title: "Result", subtitle: "Side-by-side draft preview" do
                line :briefing, entry.fetch(:briefing, "--"), placeholder: "--"
                line :checked_at, entry.fetch(:checked_at), as: :datetime
              end

              card title: "Prompt Package", subtitle: "What Companion would hand off to the external API lane" do
                page_context.compare_prompt_package_rows(entry).each do |row|
                  line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                end
                viz page_context.compare_prompt_package_preview(entry), compact: true
              end
            end
          end
        end
      end
    end
  end

  columns.aside do
    panel title: "Assistant Runtime",
          subtitle: "Choose how Companion drafts briefings before they reach the operator.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      form action: page_context.route("/assistant/runtime"), method: "post", class: "grid gap-3" do
        label "Mode",
              for: "assistant-runtime-mode",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        select id: "assistant-runtime-mode",
               name: "mode",
               class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white focus:border-orange-300/50 focus:outline-none" do
          option "Manual", value: "manual", selected: page_context.assistant_runtime_form_defaults.fetch("mode") == "manual"
          option "Ollama", value: "ollama", selected: page_context.assistant_runtime_form_defaults.fetch("mode") == "ollama"
        end

        input type: "hidden", name: "provider", value: page_context.assistant_runtime_form_defaults.fetch("provider")

        label "Model",
              for: "assistant-runtime-model",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-runtime-model",
              name: "model",
              value: page_context.assistant_runtime_form_defaults.fetch("model"),
              placeholder: "qwen2.5-coder:latest",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        label "Base URL",
              for: "assistant-runtime-base-url",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-runtime-base-url",
              name: "base_url",
              value: page_context.assistant_runtime_form_defaults.fetch("base_url"),
              placeholder: "http://127.0.0.1:11434",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        label "Timeout (seconds)",
              for: "assistant-runtime-timeout",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "number",
              id: "assistant-runtime-timeout",
              name: "timeout_seconds",
              min: "5",
              max: "300",
              value: page_context.assistant_runtime_form_defaults.fetch("timeout_seconds"),
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        label "Delivery Mode",
              for: "assistant-runtime-delivery-mode",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        select id: "assistant-runtime-delivery-mode",
               name: "delivery_mode",
               class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white focus:border-orange-300/50 focus:outline-none" do
          option "Simulate", value: "simulate",
                             selected: page_context.assistant_runtime_form_defaults.fetch("delivery_mode") == "simulate"
          option "Live", value: "live",
                        selected: page_context.assistant_runtime_form_defaults.fetch("delivery_mode") == "live"
        end

        label "Delivery Strategy",
              for: "assistant-runtime-delivery-strategy",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        select id: "assistant-runtime-delivery-strategy",
               name: "delivery_strategy",
               class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white focus:border-orange-300/50 focus:outline-none" do
          option "Prefer OpenAI", value: "prefer_openai",
                                   selected: page_context.assistant_runtime_form_defaults.fetch("delivery_strategy") == "prefer_openai"
          option "Prefer Anthropic", value: "prefer_anthropic",
                                      selected: page_context.assistant_runtime_form_defaults.fetch("delivery_strategy") == "prefer_anthropic"
          option "Auto", value: "auto",
                         selected: page_context.assistant_runtime_form_defaults.fetch("delivery_strategy") == "auto"
          option "Manual Only", value: "manual_only",
                                selected: page_context.assistant_runtime_form_defaults.fetch("delivery_strategy") == "manual_only"
        end

        label "OpenAI Model",
              for: "assistant-runtime-openai-model",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-runtime-openai-model",
              name: "openai_model",
              value: page_context.assistant_runtime_form_defaults.fetch("openai_model"),
              placeholder: "gpt-4o",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        label "Anthropic Model",
              for: "assistant-runtime-anthropic-model",
              class: "text-sm font-semibold uppercase tracking-[0.18em] text-stone-300"
        input type: "text",
              id: "assistant-runtime-anthropic-model",
              name: "anthropic_model",
              value: page_context.assistant_runtime_form_defaults.fetch("anthropic_model"),
              placeholder: "claude-sonnet-4-6",
              class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"

        button "Save Runtime",
               type: "submit",
               class: "inline-flex w-fit items-center rounded-full bg-orange-400 px-5 py-2 text-sm font-semibold text-stone-950 transition hover:bg-orange-300"
      end

      card title: "Runtime Status", subtitle: "Current local assistant execution lane" do
        page_context.assistant_runtime_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end
      end

      card title: "Prompt Profile", subtitle: "Model-aware briefing posture" do
        page_context.assistant_profile_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end

        unless page_context.assistant_profile_strengths.empty?
          line :strengths, page_context.assistant_profile_strengths, as: :badge
        end
      end

      card title: "Routing", subtitle: "How Companion chooses prep and delivery channels right now" do
        page_context.assistant_routing_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end
      end

      card title: "Credential Policy",
           subtitle: "Current default stance before any future cluster secret sharing" do
        page_context.assistant_credential_policy_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end
        line :summary, page_context.assistant_credential_policy_summary, as: :code
        unless page_context.assistant_credential_policy_notes.empty?
          line :notes, page_context.assistant_credential_policy_notes, as: :badge
        end
      end

      card title: "Credential Source",
           subtitle: "Why an external API lane is ready or still missing credentials" do
        page_context.assistant_credential_status_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end
        line :summary, page_context.assistant_credential_source_summary, as: :code
        line :notes, page_context.assistant_credential_source_notes, as: :badge

        unless page_context.assistant_credential_provider_rows.empty?
          table_with page_context.assistant_credential_provider_rows, compact: true do |table|
            table.column :provider, as: :badge, badge: { size: :sm }
            table.column :env_key, as: :code
            table.column :configured_in_file, as: :boolean
            table.column :env_present, as: :boolean
            table.column :source, as: :badge, badge: { size: :sm }
            table.column :scope, as: :badge, badge: { size: :sm }
            table.column :node, as: :badge, badge: { size: :sm }
          end
        end
      end

      card title: page_context.assistant_recommendation.fetch(:title, "Best Current Lane"),
           subtitle: "What Companion would use right now based on local prep, delivery readiness, and configured policy" do
        page_context.assistant_recommendation_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end
        line :summary, page_context.assistant_recommendation_summary, as: :code
        unless page_context.assistant_recommendation_notes.empty?
          line :notes, page_context.assistant_recommendation_notes, as: :badge
        end
      end

      card title: "Evaluation Memory",
           subtitle: "Lightweight observations from what operators actually did with assistant outputs" do
        page_context.assistant_evaluation_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end

        unless page_context.assistant_evaluation_insights.empty?
          resource_list class_name: "mt-4 space-y-3" do
            page_context.assistant_evaluation_insights.each do |insight|
              li class: "rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-6 text-stone-200" do
                text_node insight
              end
            end
          end
        end

        unless page_context.assistant_evaluation_recent_rows.empty?
          table_with page_context.assistant_evaluation_recent_rows, compact: true do |table|
            table.column :created_at, as: :datetime
            table.column :action, as: :badge, badge: { size: :sm }
            table.column :scenario, as: :badge, badge: { size: :sm }, placeholder: "--"
            table.column :model, as: :code, placeholder: "--"
            table.column :status, as: :badge, badge: { size: :sm }, placeholder: "--"
            table.column :source, as: :badge, badge: { size: :sm }, placeholder: "--"
          end
        end
      end

      card title: "Prompt Package", subtitle: "Local models prepare handoff inputs for the external ChatGPT API lane" do
        line :target, page_context.assistant_runtime_routing.dig(:delivery_channel, :key) || :chatgpt_api, as: :badge
        line :target_label, page_context.assistant_runtime_routing.dig(:delivery_channel, :label) || "ChatGPT API", as: :badge
        line :target_model, page_context.assistant_runtime_routing.dig(:delivery_channel, :model) || "--", as: :code
        line :mode, :prompt_prep, as: :badge
        line :purpose, "Use local models for prompt preparation, not final production delivery.", as: :code
      end

      card title: "Available Channels", subtitle: "Credentials and model readiness across local and external lanes" do
        table_with page_context.assistant_channel_rows, compact: true do |table|
          table.column :label, as: :badge, badge: { size: :sm }
          table.column :kind, as: :badge, badge: { size: :sm }
          table.column :provider, as: :badge, badge: { size: :sm }
          table.column :model, as: :code, placeholder: "--"
          table.column :available, as: :boolean
          table.column :credentials_ready, as: :boolean
          table.column :credential_source, as: :badge, badge: { size: :sm }, placeholder: "--"
          table.column :credential_scope, as: :badge, badge: { size: :sm }, placeholder: "--"
          table.column :credential_node, as: :badge, badge: { size: :sm }, placeholder: "--"
          table.column :credential_policy, as: :badge, badge: { size: :sm }, placeholder: "--"
          table.column :policy_allowed, as: :boolean
          table.column :reason, as: :badge, badge: { size: :sm }
        end
      end

      unless page_context.available_model_badges.empty?
        card title: "Detected Models", subtitle: "Models reported by local Ollama" do
          line :available, page_context.available_model_badges, as: :badge
        end
      end
    end

    panel title: "Actionable Follow-ups",
          subtitle: "Manual completion lane for the current operator.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      if page_context.actionable_assistant_requests.empty?
        empty_state "No assistant follow-ups waiting",
                    message: "Open a request and Companion will push the next operator action into this lane.",
                    class_name: "mt-1"
      else
        resource_list class_name: "space-y-4" do
          page_context.actionable_assistant_requests.each do |record|
            li class: "rounded-3xl border border-white/10 bg-white/5 p-4" do
              div class: "flex items-center justify-between gap-3" do
                strong record.fetch(:requester), class: "font-semibold text-white"
                badge record.fetch(:status), size: :sm
              end
              p record.fetch(:request), class: "mt-2 text-sm leading-6 text-stone-300"
              unless page_context.scenario_context_rows(record).empty?
                card title: "Incident Snapshot", subtitle: "Structured triage context carried into the operator lane" do
                  page_context.scenario_context_rows(record).each do |row|
                    line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                  end
                end
              end
              unless page_context.operator_checklist_rows(record).empty?
                card title: "Suggested Checklist", subtitle: "Use this to drive the first operator move" do
                  page_context.operator_checklist_rows(record).each do |row|
                    line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
                  end
                end
              end
              form action: page_context.route("/assistant/followups/approve"), method: "post", class: "mt-4 grid gap-3" do
                input type: "hidden", name: "request_id", value: record.fetch(:id)
                textarea "",
                         name: "briefing",
                         rows: 4,
                         placeholder: "Write the operator-approved assistant brief",
                         class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
                input type: "text",
                      name: "note",
                      value: "Completed from Companion operator desk",
                      class: "w-full rounded-2xl border border-white/10 bg-[#160f0d] px-4 py-3 text-sm text-white placeholder:text-stone-500 focus:border-orange-300/50 focus:outline-none"
                button "Complete Follow-up",
                       type: "submit",
                       class: "inline-flex w-fit items-center rounded-full bg-orange-400 px-5 py-2 text-sm font-semibold text-stone-950 transition hover:bg-orange-300"
              end
            end
          end
        end
      end
    end

    panel title: "Assistant Summary",
          subtitle: "Current workflow pressure across the request lane.",
          class_name: "rounded-[30px] border border-white/10 bg-[#2a1914]/90 p-6 shadow-2xl shadow-black/20 backdrop-blur" do
      card title: "Current State", subtitle: "Assistant workflow summary" do
        page_context.assistant_signal_rows.each do |row|
          line row.fetch(:label), row.fetch(:value), as: row.fetch(:as)
        end
      end
    end
  end
end
