html lang: "en" do
  head do
    meta charset: "utf-8"
    meta name: "viewport", content: "width=device-width, initial-scale=1"
    title page_title
    script src: tailwind_cdn_url
    script(type: "text/javascript") { raw_text tailwind_config_script }
  end

  body class: body_class do
    main class: main_class do
      sidebar_shell title: page_context.shell_title,
                    subtitle: page_context.shell_subtitle,
                    sections: page_context.shell_sections,
                    summary_items: page_context.shell_summary_items do
        render_template_content
      end
    end

    render_frontend_javascript "application"
  end
end
