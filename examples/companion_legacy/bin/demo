#!/usr/bin/env ruby
# frozen_string_literal: true

# Companion AI Assistant — full demo (no server, no hardware needed).
#
# Usage (mock executors — runs anywhere):
#   ruby bin/demo
#
# With a real LLM (requires Ollama running locally):
#   COMPANION_REAL_LLM=1 ruby bin/demo
#
# With Consensus replicated notes store (3-node in-process cluster):
#   COMPANION_CONSENSUS=1 ruby bin/demo

require_relative "../lib/companion/boot"

Companion::Boot.setup_load_path!
Dir.chdir(Companion::Boot.root)

require "igniter"
require "base64"
require "igniter/core"
require "igniter/sdk/ai"

Companion::Boot.load_demo!(real_llm: ENV["COMPANION_REAL_LLM"])

puts ENV["COMPANION_REAL_LLM"] ? "[demo] Using real LLM executors (Ollama must be running)" :
                                 "[demo] Using mock executors (no hardware/Ollama needed)"

hr = "=" * 60

# ── Section 1: Tool & Skill catalog ───────────────────────────────────────────
puts
puts hr
puts "  Tools & Skills available to ChatExecutor"
puts hr
puts "  Tools  = atomic operations (stateless, instant)"
puts "  Skills = agentic sub-processes (own LLM loop + sub-tools)"
puts

COMPANION_CATALOG = [
  Companion::TimeTool,
  Companion::WeatherTool,
  Companion::SaveNoteTool,
  Companion::GetNotesTool,
  Companion::ResearchSkill,
  Companion::RemindMeSkill,
].freeze

COMPANION_CATALOG.each do |klass|
  kind   = klass < Igniter::AI::Skill ? "skill" : "tool"
  schema = klass.to_schema
  caps   = klass.required_capabilities
  cap_s  = caps.any? ? " (requires: #{caps.join(", ")})" : ""

  puts "  [#{kind.center(5)}] #{klass.tool_name}#{cap_s}"
  puts "           #{schema[:description]}"
  params = schema.dig(:parameters, "properties") || {}
  if params.any?
    params.each do |name, info|
      req = (schema.dig(:parameters, "required") || []).include?(name.to_s) ? "*" : " "
      puts "           #{req} #{name} (#{info["type"]}): #{info["description"]}"
    end
  else
    puts "           (no parameters)"
  end
  puts
end

puts "  Capability guard — SaveNoteTool without :storage:"
save_tool = Companion::SaveNoteTool.new
begin
  save_tool.call_with_capability_check!(allowed_capabilities: [], key: "test", value: "x")
rescue Igniter::Tool::CapabilityError => e
  puts "  [ok] CapabilityError: #{e.message}"
end
result = save_tool.call_with_capability_check!(
  allowed_capabilities: [:storage], key: "demo_key", value: "hello"
)
puts "  [ok] Allowed → #{result}"
Companion::NotesStore.reset!

puts
puts "  ResearchSkill (mock):"
puts "  " + Companion::ResearchSkill.new.call(topic: "Ruby")

puts
puts "  RemindMeSkill (mock):"
puts "  " + Companion::RemindMeSkill.new.call(request: "remind me to call Alice tomorrow at 9am")
puts "  Notes after reminder: #{Companion::NotesStore.all.inspect}"
Companion::NotesStore.reset!

# ── Section 2: Consensus-backed notes store (optional) ────────────────────────
if ENV["COMPANION_CONSENSUS"]
  require "igniter/cluster"
  Companion::Boot.require_path("lib/companion/shared/session_state_machine.rb")

  puts
  puts hr
  puts "  Consensus Cluster — Replicated Notes Store"
  puts hr
  puts
  puts "  Starting 3-node Raft cluster with SessionStateMachine..."

  cluster = Igniter::Cluster::Consensus::Cluster.start(
    nodes:         [:companion_1, :companion_2, :companion_3],
    state_machine: Companion::SessionStateMachine,
    verbose:       false
  )
  cluster.wait_for_leader(timeout: 4)
  puts "  Leader: #{cluster.leader.name}  quorum: #{cluster.quorum_size}/#{cluster.alive_count}"

  Companion::NotesStore.configure_cluster(cluster)

  Companion::NotesStore.save("favorite_language", "Ruby")
  cluster.write(type: :append_turn, role: "user",      content: "Hello!")
  cluster.write(type: :append_turn, role: "assistant", content: "Hi!")

  snapshot = cluster.state_machine_snapshot
  puts "  Notes:   #{snapshot[:notes]}"
  puts "  History: #{snapshot[:history].size} turn(s)"

  first_node = cluster.instance_variable_get(:@refs).values.first
  first_node.stop
  sleep 0.2
  puts "  After killing 1 node — alive=#{cluster.alive_count}  quorum=#{cluster.has_quorum?}"
  puts "  Notes still readable: #{Companion::NotesStore.all.inspect}"
  puts "  [ok] Quorum reads survive single node failure"

  at_exit { cluster.stop!(timeout: 2) rescue nil }
end

def fake_audio
  Base64.strict_encode64("\x00\x00" * 1600)
end

puts
puts hr
puts "  Companion AI Assistant — Pipeline Demo"
puts hr
mode = ENV["COMPANION_REAL_LLM"] ? "real LLM (Ollama)" : "mock executors"
puts "  Mode: #{mode}"
puts

history = []
session_id = "demo-#{Time.now.to_i}"
turns = (ENV["COMPANION_TURNS"] || "3").to_i

turns.times do |i|
  puts "── Turn #{i + 1} " + "─" * 44
  contract = Companion::LocalPipelineContract.new(
    audio_data:           fake_audio,
    conversation_history: history,
    session_id:           session_id
  )
  begin
    result = contract.result
    puts "  Heard:    \"#{result.transcript}\""
    puts "  Intent:   #{result.intent[:category]} (#{(result.intent[:confidence] * 100).round}%)"
    puts "  Response: \"#{result.response_text}\""
    puts "  Audio:    #{result.audio_response.length} chars (Base64 WAV)"
    notes = Companion::NotesStore.all
    puts "  Notes:    #{notes}" unless notes.empty?

    history << { role: "user",      content: result.transcript }
    history << { role: "assistant", content: result.response_text }
    history = history.last(20)
  rescue Igniter::Error => e
    puts "  [ERROR] #{e.message}"
  end
  puts
end

puts hr
puts "  Proactive Agents Demo"
puts hr

def call_handler(klass, type, state, payload = {})
  handler = klass.handlers[type]
  raise "No handler :#{type} on #{klass}" unless handler
  handler.call(state: state, payload: payload)
end

# 1. Generic ProactiveAgent
puts
puts "1 · Custom ProactiveAgent — TemperatureMonitor"
class TemperatureMonitor < Igniter::Agents::ProactiveAgent
  intent "Alert when server room temperature exceeds safe range"
  SENSOR = [22.0, 24.5, 26.0, 28.3, 32.1, 35.7].cycle
  scan_interval 2.0
  watch :temp_celsius, poll: -> { SENSOR.next }
  trigger :overheating,
    condition: ->(ctx) { ctx[:temp_celsius].to_f > 30 },
    action:    ->(state:, context:) {
      puts "  ⚠ TRIGGER :overheating  temp=#{context[:temp_celsius]}°C"
      state.merge(last_alert: context[:temp_celsius])
    }
  proactive_initial_state last_alert: nil
end

state = TemperatureMonitor.default_state
6.times do |i|
  state = call_handler(TemperatureMonitor, :_scan, state)
  puts "  Scan #{i + 1}: temp=#{state[:context][:temp_celsius]}°C  " \
       "triggers=#{state[:trigger_history].size}"
end

# 2. AlertAgent
puts
puts "2 · AlertAgent — API threshold monitoring"
class ApiMonitor < Igniter::Agents::AlertAgent
  intent "Watch API error rate and latency"
  scan_interval 5.0
  monitor :error_rate, source: -> { 0.08 }
  monitor :p99_ms,     source: -> { 350 }
  threshold :error_rate, above: 0.05
  threshold :p99_ms,     above: 500
  proactive_initial_state alerts: [], silenced: false
end

state  = ApiMonitor.default_state
state  = call_handler(ApiMonitor, :_scan, state)
alerts = call_handler(ApiMonitor, :alerts, state)
puts "  Alerts fired: #{alerts.size}"
alerts.each { |a| puts "  → #{a.metric}=#{a.value} #{a.kind} #{a.threshold}" }
state  = call_handler(ApiMonitor, :silence, state)
state  = call_handler(ApiMonitor, :_scan, state)
alerts2 = call_handler(ApiMonitor, :alerts, state)
puts "  After silence — still #{alerts2.size} (no new alerts added)"

# 3. HealthCheckAgent
puts
puts "3 · HealthCheckAgent — dependency liveness"
class InfraHealth < Igniter::Agents::HealthCheckAgent
  intent "Monitor database and cache"
  scan_interval 15.0
  check :database, poll: -> { true  }
  check :cache,    poll: -> { false }
  proactive_initial_state health: {}, transitions: []
end

state       = InfraHealth.default_state
state       = call_handler(InfraHealth, :_scan, state)
health      = call_handler(InfraHealth, :health, state)
all_ok      = call_handler(InfraHealth, :all_healthy, state)
transitions = call_handler(InfraHealth, :transitions, state)
puts "  Health: #{health}  all_healthy: #{all_ok}"
puts "  Transitions: #{transitions.map { |t| "#{t.service}:#{t.from}→#{t.to}" }}"
state = call_handler(InfraHealth, :_scan, state)
puts "  After 2nd scan transitions: #{call_handler(InfraHealth, :transitions, state).size} (no duplicate)"

# 4. ConversationNudgeAgent
puts
puts "4 · ConversationNudgeAgent — reactive + proactive"
state = Companion::ConversationNudgeAgent.default_state
3.times { |i| state = call_handler(Companion::ConversationNudgeAgent, :record_turn, state, role: :user, text: "Weather #{i}?") }
state  = call_handler(Companion::ConversationNudgeAgent, :_scan, state)
nudges = call_handler(Companion::ConversationNudgeAgent, :nudges, state)
puts "  After 3 unanswered turns — nudges: #{nudges.size}"
nudges.first(2).each { |n| puts "  → [#{n.kind}] #{n.suggestion}" }

# 5. Pause / resume
puts
puts "5 · Pause / resume"
state  = ApiMonitor.default_state
state  = call_handler(ApiMonitor, :pause, state)
status = call_handler(ApiMonitor, :status, state)
puts "  After :pause  — active=#{status.active}"
state  = call_handler(ApiMonitor, :resume, state)
status = call_handler(ApiMonitor, :status, state)
puts "  After :resume — active=#{status.active}"

puts
puts hr
puts "  Done! Run  bin/start  →  http://localhost:4567"
puts hr
puts
