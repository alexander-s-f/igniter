section class: "relative overflow-hidden rounded-[2rem] border border-stone-800 bg-stone-900/80 p-8 shadow-glow" do
  div class: "absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-amber-400/60 to-transparent"

  div class: "flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between" do
    div class: "max-w-3xl space-y-3" do
      p "Operator Surface", class: "text-xs font-semibold uppercase tracking-[0.28em] text-amber-300/80"
      h1 page_context.title, class: "font-display text-4xl tracking-tight text-stone-50 sm:text-5xl"
      p "Mounted stack overview generated by the dashboard scaffold profile.", class: "max-w-2xl text-sm leading-6 text-stone-300 sm:text-base"
      p class: "text-sm text-stone-500" do
        text_node "root_app=#{page_context.stack["root_app"]} · "
        text_node "default_node=#{page_context.stack["default_node"]} · "
        text_node "current_node=#{page_context.current_node}"
      end
    end

    div class: "flex flex-wrap items-center gap-3" do
      a "Refresh", href: page_context.route("/"), class: "rounded-full border border-stone-700 px-4 py-2 text-sm font-medium text-stone-100 transition hover:border-amber-300 hover:text-amber-200"
      a "Operator Console", href: page_context.route("/operator"), class: "rounded-full bg-amber-500 px-4 py-2 text-sm font-semibold text-stone-950 transition hover:bg-amber-400"
      a "Operator API", href: page_context.route("/api/operator"), class: "rounded-full border border-stone-700 px-4 py-2 text-sm font-medium text-stone-100 transition hover:border-amber-300 hover:text-amber-200"
    end
  end
end

section class: "grid gap-4 md:grid-cols-2 xl:grid-cols-4" do
  page_context.summary_metrics.each do |metric|
    article class: "rounded-3xl border border-stone-800 bg-stone-900/70 p-5" do
      p metric.fetch(:label), class: "text-xs font-semibold uppercase tracking-[0.22em] text-stone-500"
      p metric.fetch(:value).to_s, class: "mt-3 font-display text-3xl text-stone-50"
    end
  end
end

section class: "grid gap-4 xl:grid-cols-3" do
  page_context.panel_payloads.each do |entry|
    article class: "rounded-3xl border border-stone-800 bg-stone-900/70 p-5" do
      div class: "flex items-center justify-between gap-3" do
        h2 entry.fetch(:title), class: "font-display text-2xl text-stone-50"
        span "json", class: "rounded-full border border-stone-700 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-400"
      end

      pre pretty_json(entry.fetch(:payload)), class: "mt-4 overflow-x-auto rounded-2xl border border-stone-800 bg-stone-950/80 p-4 text-xs leading-6 text-stone-300"
    end
  end
end
