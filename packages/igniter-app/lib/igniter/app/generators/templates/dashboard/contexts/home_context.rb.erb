# frozen_string_literal: true

module <%= module_name %>
  module Dashboard
    module Contexts
      class HomeContext < Igniter::Frontend::Context
        def title
          fetch(:title)
        end

        def snapshot
          fetch(:snapshot)
        end

        def stack
          snapshot.fetch(:stack)
        end

        def apps
          snapshot.fetch(:apps)
        end

        def nodes
          snapshot.fetch(:nodes)
        end

        def mounts
          stack.fetch("mounts", {})
        end

        def current_node
          snapshot.fetch(:current_node)
        end

        def summary_metrics
          [
            { label: "Apps", value: apps.size },
            { label: "Mounts", value: mounts.size },
            { label: "Nodes", value: nodes.size },
            { label: "Current Node", value: current_node }
          ]
        end

        def panel_payloads
          [
            { title: "Mounted Apps", payload: apps },
            { title: "Mounts", payload: mounts },
            { title: "Nodes", payload: nodes }
          ]
        end
      end
    end
  end
end
