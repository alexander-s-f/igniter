# frozen_string_literal: true

require "igniter-frontend"
require_relative "../../contexts/home_context"
require_relative "../../support/stack_overview"
require_relative "../views/home_page"

module <%= module_name %>
  module Dashboard
    module Web
      module Handlers
        class HomeHandler < Igniter::Frontend::Handler
          def call
            render(
              Views::HomePage,
              context: build_context(
                Contexts::HomeContext,
                title: "<%= module_name %> Dashboard",
                snapshot: Support::StackOverview.build
              )
            )
          end
        end
      end
    end
  end
end
