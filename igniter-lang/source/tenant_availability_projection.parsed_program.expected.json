{
  "kind": "source_file",
  "grammar_version": "spark-pipeline-v0",
  "module": "SparkCRM.Availability",
  "imports": [
    {
      "module_path": "SparkCRM.Types",
      "names": [
        "TechnicianProfile", "ScheduleSlotObservation",
        "OffScheduleBlock", "DayOffConfigVersion",
        "AvailabilitySnapshot", "TimeSlot", "TenantScope"
      ]
    }
  ],
  "traits": [],
  "impls": [],
  "contract_shapes": [],
  "types": [],
  "functions": [],
  "pipelines": [],
  "contracts": [
    {
      "kind": "contract",
      "name": "TenantAvailabilityProjection",
      "type_params": [],
      "body": [
        { "kind": "input", "name": "technician_id", "type_annotation": "String" },
        { "kind": "input", "name": "date",          "type_annotation": "String" },
        { "kind": "input", "name": "company_scope", "type_annotation": "TenantScope" },
        { "kind": "escape", "name": "scoped_tbackend_read" },
        {
          "kind": "read",
          "name": "technician",
          "type_annotation": "TechnicianProfile",
          "from": "technician/{technician_id}",
          "lifecycle": "durable",
          "scoped_by": "company_scope",
          "cardinality": { "min": 1, "max": 1 },
          "schema_version": "technician-profile-v1",
          "tenant_free": false
        },
        {
          "kind": "read",
          "name": "schedules",
          "type_annotation": "Collection[ScheduleSlotObservation]",
          "from": "schedule/{technician_id}/{date}",
          "lifecycle": "durable",
          "scoped_by": "company_scope",
          "cardinality": { "min": 0, "max": 500 },
          "schema_version": "schedule-slot-v1",
          "tenant_free": false
        },
        {
          "kind": "read",
          "name": "off_schedules",
          "type_annotation": "Collection[OffScheduleBlock]",
          "from": "off_schedule/{technician_id}/{date}",
          "lifecycle": "window",
          "scoped_by": "company_scope",
          "cardinality": { "min": 0, "max": 200 },
          "schema_version": "off-schedule-v1",
          "tenant_free": false
        },
        {
          "kind": "read",
          "name": "day_off_config",
          "type_annotation": "DayOffConfigVersion",
          "from": "day_off_config/{technician_id}",
          "lifecycle": "durable",
          "scoped_by": "company_scope",
          "cardinality": { "min": 0, "max": 1 },
          "schema_version": "day-off-config-v1",
          "tenant_free": false
        },
        {
          "kind": "compute",
          "name": "available_slots",
          "expr": {
            "kind": "call",
            "fn": "compute_availability",
            "args": [
              { "kind": "ref", "name": "technician" },
              { "kind": "ref", "name": "schedules" },
              { "kind": "ref", "name": "off_schedules" },
              { "kind": "ref", "name": "day_off_config" },
              { "kind": "ref", "name": "date" }
            ]
          }
        },
        {
          "kind": "snapshot",
          "name": "snap",
          "expr": {
            "kind": "call",
            "fn": "build_snapshot",
            "args": [
              { "kind": "ref", "name": "available_slots" },
              { "kind": "ref", "name": "technician_id" },
              { "kind": "ref", "name": "date" }
            ]
          },
          "lifecycle": "durable"
        },
        { "kind": "output", "name": "available_slots",
          "type_annotation": "Collection[TimeSlot]", "lifecycle": "window" },
        { "kind": "output", "name": "snap",
          "type_annotation": "AvailabilitySnapshot",  "lifecycle": "durable" }
      ]
    }
  ],
  "parse_errors": []
}
