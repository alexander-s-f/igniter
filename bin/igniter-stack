#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"

options = {
  port: 4567,
  host: "0.0.0.0",
  requires: [],
  config: nil,
  minimal: false,
  profile: nil
}

global = OptionParser.new do |opts|
  opts.banner = <<~BANNER
    igniter-stack — stack scaffold and HTTP server toolkit for Igniter

    Usage:
      igniter-stack start [options]
      igniter-stack new APP_NAME [--minimal] [--profile dashboard|cluster|playground]

  BANNER

  opts.on("--port PORT", Integer, "Port to listen on (default: 4567)") { |v| options[:port] = v }
  opts.on("--host HOST",          "Host to bind to (default: 0.0.0.0)") { |v| options[:host] = v }
  opts.on("--require FILE",       "Require a file (can be used multiple times)") { |v| options[:requires] << v }
  opts.on("--config FILE",        "Load a server config file") { |v| options[:config] = v }
  opts.on("--minimal",            "Skip demo scaffold — only create directory structure") { options[:minimal] = true }
  opts.on("--profile NAME",       "Scaffold profile (e.g. dashboard, cluster, playground)") { |v| options[:profile] = v }
  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
  opts.on("-v", "--version", "Show version") do
    require_relative "../lib/igniter/version"
    puts "igniter-stack #{Igniter::VERSION}"
    exit
  end
end

global.parse!

command = ARGV.shift || "start"

case command
when "start"
  options[:requires].each { |f| require File.expand_path(f) }
  load File.expand_path(options[:config]) if options[:config]

  require_relative "../lib/igniter/server"
  require_relative "../lib/igniter/version"

  Igniter::Server.start(port: options[:port], host: options[:host])

when "new"
  app_name = ARGV.shift
  if app_name.nil? || app_name.strip.empty?
    warn "Usage: igniter-stack new APP_NAME"
    exit 1
  end

  if File.exist?(app_name)
    warn "Error: '#{app_name}' already exists"
    exit 1
  end

  require_relative "../lib/igniter/app/scaffold_pack"

  mode = options[:minimal] ? " (minimal)" : ""
  puts "Creating Igniter stack '#{app_name}'#{mode}..."
  generator_class =
    case options[:profile].to_s.strip
    when "", "default", "base"
      Igniter::App::Generator
    when "dashboard"
      Igniter::App::Generators::Dashboard
    when "cluster"
      Igniter::App::Generators::Cluster
    when "playground"
      Igniter::App::Generators::Playground
    else
      warn "Unknown scaffold profile: #{options[:profile].inspect}"
      warn "Available profiles: dashboard, cluster, playground"
      exit 1
    end

  generator_class.new(app_name, minimal: options[:minimal]).generate

else
  warn "Unknown command: #{command}"
  warn "Available commands: start, new"
  exit 1
end
